{
  "name": "jm-agent-cli",
  "version": "0.1.0",
  "description": "Agent-first JMComic CLI built with JS/Node",
  "type": "module",
  "bin": {
    "jm-agent": "./bin/jm-agent.js"
  },
  "scripts": {
    "start": "node ./bin/jm-agent.js",
    "smoke:config": "node ./bin/jm-agent.js config --json",
    "smoke:discover": "node ./bin/jm-agent.js discover --provider jm --query love --limit 5 --json",
    "smoke:resolve": "node ./bin/jm-agent.js resolve --provider jm --query love --limit 3 --json",
    "check": "node ./scripts/check-syntax.mjs",
    "test": "node --test",
    "verify": "npm run check && npm test && npm pack --dry-run --ignore-scripts",
    "prepublishOnly": "npm run verify",
    "smoke:online": "node ./scripts/smoke-online.mjs",
    "validate:auth-online": "node ./scripts/validate-auth-online.mjs",
    "validate:favorites-online": "node ./scripts/validate-favorites-online.mjs",
    "validate:download-online": "node ./scripts/validate-download-online.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "files": [
    "bin/",
    "scripts/",
    "skills/",
    "src/",
    "test/",
    "tools/vendor/"
  ],
  "dependencies": {
    "adm-zip": "^0.5.17",
    "pdfkit": "^0.18.0",
    "sharp": "^0.34.5"
  }
}
